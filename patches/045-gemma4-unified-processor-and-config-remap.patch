+            #
+            # Apply this remap to BOTH config.text_config (multimodal path, e.g.
+            # gemma4 26B MoE) AND the top-level config (the dense text-only path
+            # Gemma4ForCausalLM, e.g. gemma4-31b, consumes the top-level
+            # Gemma4Config directly — without this it sees head_dim=256 for
+            # full-attention layers and crashes loading the 512-dim q/k_norm +
+            # k/v projections; the KV pool also needs swa_head_dim). The
+            # swa_head_dim guard makes it idempotent / skip the non-applicable.
+            def _remap_gemma4_head_dims(tc):
+                if tc is None or getattr(tc, "swa_head_dim", None) is not None:
+                    return
+                if getattr(tc, "head_dim", None) is None:
+                    return
+                global_head_dim = getattr(tc, "global_head_dim", None)
+                global_kv_heads = getattr(tc, "num_global_key_value_heads", None)
+
+                tc.swa_head_dim = tc.head_dim
+                tc.swa_v_head_dim = tc.head_dim
+                tc.swa_num_key_value_heads = tc.num_key_value_heads
+
+                if global_head_dim is not None:
+                    tc.head_dim = global_head_dim
+                if global_kv_heads is not None:
+                    tc.num_key_value_heads = global_kv_heads
+
+                if not hasattr(tc, "v_head_dim"):
+                    tc.v_head_dim = tc.head_dim
+                if not hasattr(tc, "swa_v_head_dim"):
+                    tc.swa_v_head_dim = tc.swa_head_dim
+
+            _remap_gemma4_head_dims(getattr(config, "text_config", None))
+            _remap_gemma4_head_dims(config)
+
+            # gemma4_unified (12B) names end-of-audio `eoa_token_index`, but the
+            # shared Gemma4 multimodal processor reads `eoa_token_id` (the 26B/31B
+            # naming). All other mm token ids match; alias just this one so the
+            # processor __init__ doesn't AttributeError. Idempotent.
+            if config.model_type == "gemma4_unified" and not hasattr(
+                config, "eoa_token_id"
+            ):
+                eoa = getattr(config, "eoa_token_index", None)
+                if eoa is not None:
+                    config.eoa_token_id = eoa
 
         if config.model_type == "longcat_flash":
             _set_architectures(config, "LongcatFlashForCausalLM")
