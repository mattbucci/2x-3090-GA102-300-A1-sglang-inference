+
+        data = {
+            "pixel_values": pixel_values,
+            "image_position_ids": position_ids,
+            "num_soft_tokens_per_image": num_soft_tokens_per_image,
+        }
+        return BatchFeature(data=data, tensor_type=return_tensors)
+
+
+__all__ = ["Gemma4UnifiedImageProcessor"]
