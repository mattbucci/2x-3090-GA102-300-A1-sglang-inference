                 name = name.replace(r"model.language_model.", r"model.")
             if ".self_attn." in name:
                 name = name.replace(".self_attn", "")
+
+            # CT-format shared_expert_gate dequant on-the-fly.
+            # qwen2_moe.py constructs shared_expert_gate as plain torch.nn.Linear
+            # on the GPU path (no quant_config plumbed in), so the model's
+            # params_dict has only `shared_expert_gate.weight`, never
+            # `weight_packed/scale/shape`. CT-format checkpoints ship the
+            # quantized triplet (recipe didn't ignore the gate) — without this
+            # bridge SGLang prints 120 missing-param warnings + serves
+            # gibberish. Buffer the 3-tuple per layer; once all 3 are seen,
+            # dequant int4 → bf16 and write to the layer's `.weight`.
+            # Tracked: evals/awq-audit-2026-05-07.md (Qwen3.6-35B CT-on-NVIDIA).
+            # No-op on Dense Conditional class (no shared_expert_gate keys).
+            if "shared_expert_gate" in name and (
+                name.endswith(".weight_packed")
+                or name.endswith(".weight_scale")
+                or name.endswith(".weight_shape")
+            ):
+                if not hasattr(self, "_seg_buf"):
+                    self._seg_buf = {}
+                base, suffix = name.rsplit(".", 1)
+                self._seg_buf.setdefault(base, {})[suffix] = loaded_weight
+                if len(self._seg_buf[base]) == 3:
+                    from compressed_tensors.compressors import unpack_from_int32
+                    wp = self._seg_buf[base]["weight_packed"]
+                    ws = self._seg_buf[base]["weight_scale"]
+                    sh = self._seg_buf[base]["weight_shape"]
+                    target_shape = torch.Size(sh.tolist())
+                    group_size = target_shape[1] // ws.shape[1]
+                    int4 = unpack_from_int32(
+                        wp, num_bits=4, shape=target_shape, packed_dim=1
+                    )
+                    bf16 = int4.to(torch.bfloat16) * ws.repeat_interleave(
+                        group_size, dim=-1
+                    )
+                    weight_name = base + ".weight"
+                    if weight_name in params_dict:
+                        params_dict[weight_name].data.copy_(bf16)
+                        loaded_params.add(weight_name)
+                    del self._seg_buf[base]
+                loaded_params.add(name)
+                continue
+
             if (
                 self.config.tie_word_embeddings
                 and self.pp_group.is_last_rank
