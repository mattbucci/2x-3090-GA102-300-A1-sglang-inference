# patch 048 — add the missing __call__ to the vendored Gemma4UnifiedProcessor (vision/audio/video serving).
#
# Patch 046 vendored the unified processor's HOOKS (prepare_inputs_layout / validate_inputs /
# replace_image_token) but NOT its __call__. In transformers 5.10 the base ProcessorMixin.__call__
# orchestrates those hooks to EXPAND each <|image|> placeholder into N soft tokens; our tx 5.5.4
# ProcessorMixin.__call__ does no expansion, so input_ids kept a single image placeholder while the
# vision embedder emitted N patch embeddings -> SGLang mm_utils 'split_with_sizes expected N got [1]'
# on the first image request (server crash). Fix = add a __call__ modeled on the working 26B
# transformers Gemma4Processor (image+video+audio expansion via boi/eoi/boa/eoa + soft-token repeat),
# inlined so it doesn't depend on super().prepare_inputs_layout (absent in 5.5.4). Verified 2026-06-07:
# 12B AWQ answers 'Red' to a red image and the server survives; offline image_tokens==valid_patches. -MB
#
--- a/python/sglang/srt/configs/processing_gemma4_unified.py
+++ b/python/sglang/srt/configs/processing_gemma4_unified.py
@@ -136,6 +136,79 @@
             **kwargs,
         )
 
+    def __call__(self, images=None, text=None, audio=None, videos=None, **kwargs):
+        # BACKPORT (-MB 2026-06-07): tx 5.10's ProcessorMixin has a generic __call__
+        # that orchestrates the prepare_inputs_layout / replace_*_token hooks; our
+        # tx 5.5.4 base ProcessorMixin.__call__ does NOT expand multimodal placeholders,
+        # so without this the single <|image|> token never expands to N soft tokens —
+        # the vision embedder emits N patch embeddings but input_ids has 1 placeholder,
+        # and SGLang's mm_utils crashes ("split_with_sizes expected N got [1]"). Modeled
+        # on the working transformers Gemma4Processor (26B) __call__; inlined layout so it
+        # does not depend on super().prepare_inputs_layout (absent in 5.5.4).
+        import re as _re
+        from transformers import BatchFeature
+
+        if text is None and images is None and audio is None and videos is None:
+            raise ValueError("Provide at least one of `text`, `images`, `audio`, or `videos`.")
+        output_kwargs = self._merge_kwargs(
+            Gemma4UnifiedProcessorKwargs,
+            tokenizer_init_kwargs=self.tokenizer.init_kwargs,
+            **kwargs,
+        )
+        if isinstance(text, str):
+            text = [text]
+
+        image_inputs = {}
+        if images is not None:
+            if hasattr(self.image_processor, "fetch_images"):
+                images = self.image_processor.fetch_images(images)
+            batched_images = make_nested_list_of_images(images)
+            image_inputs = self.image_processor(images, **output_kwargs["images_kwargs"])
+            num_soft_tokens = image_inputs.pop("num_soft_tokens_per_image")
+            if not text:
+                text = [" ".join([self.image_token] * len(ims)) for ims in batched_images]
+            replacements = iter(
+                [f"{self.boi_token}{self.image_token * int(n)}{self.eoi_token}" for n in num_soft_tokens]
+            )
+            pattern = _re.escape(self.image_token)
+            text = [_re.sub(pattern, lambda _m: next(replacements), p) for p in text]
+
+        video_inputs = {}
+        if videos is not None:
+            video_inputs = self.video_processor(videos=videos, **output_kwargs["videos_kwargs"])
+            num_v = video_inputs.pop("num_soft_tokens_per_video")
+            video_inputs.pop("video_metadata", None)
+            vreplacements = iter(
+                [f"{self.boi_token}{self.video_token * int(n)}{self.eoi_token}" for n in num_v]
+            )
+            vpattern = _re.escape(self.video_token)
+            text = [_re.sub(vpattern, lambda _m: next(vreplacements), p) for p in text]
+
+        audio_inputs = {}
+        if audio is not None:
+            if isinstance(audio, np.ndarray) and audio.ndim == 1:
+                audio = [audio]
+            audio_inputs = self.feature_extractor(audio, **output_kwargs.get("audio_kwargs", {}))
+            sr = getattr(self.feature_extractor, "sampling_rate", 16000)
+            num_audio = [
+                int(math.ceil((len(np.asarray(a)) / sr * 1000) / self.audio_ms_per_token)) for a in audio
+            ]
+            if not text:
+                text = [self.audio_token] * len(audio)
+            areplacements = iter(
+                [f"{self.boa_token}{self.audio_token * n}{self.eoa_token}" for n in num_audio]
+            )
+            apattern = _re.escape(self.audio_token)
+            text = [_re.sub(apattern, lambda _m: next(areplacements), p) for p in text]
+
+        return_tensors = output_kwargs["text_kwargs"].pop("return_tensors", None)
+        output_kwargs["text_kwargs"].pop("return_mm_token_type_ids", None)
+        text_inputs = self.tokenizer(text=text, **output_kwargs["text_kwargs"])
+        return BatchFeature(
+            data={**text_inputs, **image_inputs, **video_inputs, **audio_inputs},
+            tensor_type=return_tensors,
+        )
+
     def prepare_inputs_layout(
