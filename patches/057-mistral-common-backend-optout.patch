+        # the `"fix_mistral_regex" not in kwargs` gate). False loads
+        # tokenizer.json verbatim — token ids verified bit-identical to the
+        # tx 5.8.1 fast tokenizer ([INST]->3, [TOOL_CALLS]->9). [3090 057]
+        mistral_common_rerouted = False
+        if type(tokenizer).__name__ == "MistralCommonBackend":
+            tokenizer = _auto_tokenizer_from_pretrained(
+                tokenizer_name, *args, fix_mistral_regex=False, **common_kwargs
+            )
+            mistral_common_rerouted = True
+
         # With fastokens, the patched TokenizersBackend.from_pretrained already
