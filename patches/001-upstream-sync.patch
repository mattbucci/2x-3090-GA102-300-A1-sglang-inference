index 000000000..80bb37061
--- /dev/null
+++ b/python/sglang/srt/multimodal/processors/gemma4.py
@@ -0,0 +1,145 @@
+# Copyright 2025 SGLang Team
+# Licensed under the Apache License, Version 2.0 (the "License");
