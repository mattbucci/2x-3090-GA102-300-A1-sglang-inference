--- a/python/sglang/srt/configs/qwen3_5.py
+++ b/python/sglang/srt/configs/qwen3_5.py
@@ -145,10 +145,22 @@ class Qwen3_5Config(PretrainedConfig):
 class Qwen3_5MoeVisionConfig(Qwen3_5VisionConfig):
     model_type = "qwen3_5_moe"
 
+    # Explicit __init__ prevents transformers' PretrainedConfig metaclass from
+    # auto-decorating this subclass as a dataclass, which would otherwise
+    # REPLACE the inherited Qwen3_5VisionConfig.__init__ with a generated one
+    # that never sets the parent's attribute defaults (hidden_size, depth,
+    # norm_topk_prob etc.).  Observed in transformers 5.x on Python 3.13.
+    def __init__(self, **kwargs):
+        super().__init__(**kwargs)
+
 
 class Qwen3_5MoeTextConfig(Qwen3_5TextConfig):
     model_type = "qwen3_5_moe_text"
 
+    # See note on Qwen3_5MoeVisionConfig.__init__.
+    def __init__(self, **kwargs):
+        super().__init__(**kwargs)
+
 
 class Qwen3_5MoeConfig(Qwen3_5Config):
     model_type = "qwen3_5_moe"
@@ -156,3 +168,7 @@ class Qwen3_5MoeConfig(Qwen3_5Config):
         "vision_config": Qwen3_5MoeVisionConfig,
         "text_config": Qwen3_5MoeTextConfig,
     }
+
+    # See note on Qwen3_5MoeVisionConfig.__init__.
+    def __init__(self, **kwargs):
+        super().__init__(**kwargs)
diff --git a/python/sglang/srt/models/qwen3_vl.py b/python/sglang/srt/models/qwen3_vl.py
index 7746b2445..3687288ef 100644
--- a/python/sglang/srt/models/qwen3_vl.py
+++ b/python/sglang/srt/models/qwen3_vl.py
@@ -1077,6 +1077,29 @@ class Qwen3VLForConditionalGeneration(nn.Module):
 
         self.use_data_parallel = get_global_server_args().mm_enable_dp_encoder
 
+        # llmcompressor-saved configs may ship text_config / vision_config as
+        # plain dicts (or as bare PreTrainedConfig without the subclass init
+        # defaults like norm_topk_prob=True) when HF's top-level loader bypasses
+        # the sub_configs dispatch. Re-wrap with the proper subclass so the
+        # downstream model/vision code sees attributes with their defaults.
+        # `model_type` must be dropped — it's a class attribute on the subclass
+        # and PreTrainedConfig.to_dict() can include an empty "" that would
+        # overwrite it when passed through __init__.
+        _subs = getattr(type(config), "sub_configs", {}) or {}
+        for _key in ("vision_config", "text_config"):
+            _sub = getattr(config, _key, None)
+            _sub_cls = _subs.get(_key)
+            if _sub_cls is None or _sub is None:
+                continue
+            if isinstance(_sub, dict):
+                _d = dict(_sub)
+            elif not isinstance(_sub, _sub_cls):
+                _d = _sub.to_dict()
+            else:
+                continue
+            _d.pop("model_type", None)
+            setattr(config, _key, _sub_cls(**_d))
+
         self.visual = Qwen3VLMoeVisionModel(
             config.vision_config,
             # NOTE: Qwen3-VL vision encoder currently supports BitsAndBytes 4-bit quantization.
