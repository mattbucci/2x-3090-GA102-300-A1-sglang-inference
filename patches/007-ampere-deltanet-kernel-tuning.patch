 from sglang.srt.layers.attention.fla.op import exp
 from sglang.srt.layers.attention.fla.utils import input_guard
 
+# sm_86 (Ampere, e.g. RTX 3090) benefits from BV=64 and num_warps=1
+# for the recurrent decode kernel. Benchmark: 1.57x speedup over BV=32.
+# See scripts/test/bench_deltanet_triton_sweep.py for methodology.
+_SM86_BV_OVERRIDE = 64
+_SM86_WARPS_OVERRIDE = 1
+_SM86_STAGES_OVERRIDE = 3
+
+def _get_deltanet_kernel_params(V: int):
+    """Return (BV, num_warps, num_stages) tuned for the current GPU."""
+    cc = torch.cuda.get_device_capability()
+    if cc == (8, 6):  # sm_86: RTX 3090, 3080, A5000, etc.
+        BV = min(triton.next_power_of_2(V), _SM86_BV_OVERRIDE)
+        return BV, _SM86_WARPS_OVERRIDE, _SM86_STAGES_OVERRIDE
+    # Default (upstream) for other architectures
+    BV = min(triton.next_power_of_2(V), 32)
+    return BV, 1, 3
+
 
